cmd_system_background_tasks() {
  _api GET "/app/system-coordinator/api/v1/backgroundTasks" \
    | python3 -c "
import sys, json

data = json.load(sys.stdin)
tasks = data.get('backgroundTasks', [])

if not tasks:
    print('  No background tasks.')
    sys.exit(0)

print(f'  {len(tasks)} background task(s)\n')

for t in tasks:
    tid = t.get('id', '-')
    status = t.get('status', '-')
    desc = t.get('description', '-')
    transitions = t.get('transitions', [])
    messages = t.get('messages', [])
    result = t.get('result')
    exception = t.get('exception')

    # Get created/completed times from transitions
    created = '-'
    for tr in transitions:
        if 'Created' in tr:
            created = tr['Created'][:19].replace('T', ' ')
            break

    print(f'  === Task: {tid} ===')
    print(f'  Status:      {status}')
    print(f'  Description: {desc}')
    print(f'  Created:     {created}')

    # Show transition timeline
    print(f'  Transitions:')
    for tr in transitions:
        for k, v in tr.items():
            print(f'    {k:<12} {v[:19].replace(\"T\", \" \")}')

    # Show last few messages (skip repetitive 'Checking' messages)
    unique_msgs = []
    for m in messages:
        msg = m.get('message', '')
        if not unique_msgs or unique_msgs[-1][0] != msg:
            unique_msgs.append((msg, m.get('timestamp', '')[:19].replace('T', ' '), 1))
        else:
            prev = unique_msgs[-1]
            unique_msgs[-1] = (prev[0], m.get('timestamp', '')[:19].replace('T', ' '), prev[2] + 1)

    print(f'  Messages:')
    for msg, ts, count in unique_msgs:
        repeat = f' (x{count})' if count > 1 else ''
        print(f'    {ts}  {msg}{repeat}')

    if exception:
        print(f'  Exception: {exception}')

    if result:
        r_status = result.get('status', '-')
        r_content = result.get('content', '')
        print(f'  Result:      HTTP {r_status}')
        try:
            parsed = json.loads(r_content)
            errors = parsed.get('errors', {})
            if errors:
                print(f'  Errors:      {json.dumps(errors)}')
            else:
                print(f'  Errors:      none')
            for key in ('bridges', 'filestores', 'handlers'):
                items = parsed.get(key, [])
                if items:
                    print(f'  {key.capitalize()}: {', '.join(items)}')
        except:
            if r_content:
                print(f'  Content:     {r_content[:200]}')

    print()
" 2>/dev/null
}

cmd_system_submission_engine() {
  local action="${1:?Usage: kinetic system submission-engine (start|stop|status)}"
  case "$action" in
    start)
      echo "Starting submission engine..."
      _api PUT "/app/system-coordinator/components/core/app/api/v1/license/reset" \
        -d '{"params":{},"headers":{"X-Kinetic-AuthAssumed":"true"}}' > /dev/null
      _api GET "/app/system-coordinator/components/core/app/api/v1/license/check" \
        | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"  Submission Engine: {d.get('application','-')}\")
" 2>/dev/null
      ;;
    stop)
      echo "Error: The Kinetic platform does not provide an API to stop the submission engine."
      echo "The engine stops automatically when the unlicensed submission limit is reached."
      exit 1
      ;;
    status)
      _api GET "/app/system-coordinator/components/core/app/api/v1/license/check" \
        | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"  Submission Engine: {d.get('application','-')}\")
print(f\"  License:           {d.get('license','-')}\")
" 2>/dev/null
      ;;
    *)
      echo "Usage: kinetic system submission-engine (start|stop|status)"
      exit 1
      ;;
  esac
}

