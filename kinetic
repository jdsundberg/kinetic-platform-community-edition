# ---------------------------------------------------------------------------
# Command dispatch
# ---------------------------------------------------------------------------

case "${1:-}" in
  --version|-V)
    echo "kineticCLI ${KINETIC_CLI_VERSION}"
    exit 0
    ;;
  # Handled before _require_config — this is what you run when no config exists.
  config)
    case "${2:-}" in
      create)
        shift 2
        cmd_config_create "$@"
        exit 0
        ;;
      *)
        echo "Usage: kinetic config create [path]"
        exit 1
        ;;
    esac
    ;;
esac

_require_config

cmd="${1:-help}"
sub="${2:-}"
shift 2 2>/dev/null || true

case "${cmd}" in
  system)
    case "${sub}" in
      info)              cmd_system_info "$@" ;;
      health)            cmd_system_health "$@" ;;
      change-password)   cmd_system_change_password "$@" ;;
      smtp-get)          cmd_system_smtp_get "$@" ;;
      smtp-set)          cmd_system_smtp_set "$@" ;;
      list-spaces)       cmd_system_list_spaces "$@" ;;
      users)             cmd_system_users "$@" ;;
      space-create)      cmd_system_space_create "$@" ;;
      space-delete)          cmd_system_space_delete "$@" ;;
      restart)               cmd_system_restart "$@" ;;
      rotate-encryption-key) cmd_system_rotate_encryption_key "$@" ;;
      background-tasks)      cmd_system_background_tasks "$@" ;;
      submission-engine)     cmd_system_submission_engine "$@" ;;
      *)                 echo "Usage: kinetic system {info|health|users|change-password|smtp-get|smtp-set|list-spaces|space-create|space-delete|restart|rotate-encryption-key|background-tasks|submission-engine}" ;;
    esac
    ;;
  space)
    case "${sub}" in
      get)     cmd_space_get "$@" ;;
      export)  cmd_space_export "$@" ;;
      import)  cmd_space_import "$@" ;;
      *)       echo "Usage: kinetic space {get|export|import}" ;;
    esac
    ;;
  user)
    case "${sub}" in
      list)             cmd_user_list "$@" ;;
      create)           cmd_user_create "$@" ;;
      get)              cmd_user_get "$@" ;;
      update)           cmd_user_update "$@" ;;
      delete)           cmd_user_delete "$@" ;;
      change-password)  cmd_user_change_password "$@" ;;
      *)                echo "Usage: kinetic user {list|create|get|update|delete|change-password}" ;;
    esac
    ;;
  team)
    case "${sub}" in
      list)           cmd_team_list "$@" ;;
      create)         cmd_team_create "$@" ;;
      delete)         cmd_team_delete "$@" ;;
      add-member)     cmd_team_add_member "$@" ;;
      remove-member)  cmd_team_remove_member "$@" ;;
      *)              echo "Usage: kinetic team {list|create|delete|add-member|remove-member}" ;;
    esac
    ;;
  kapp)
    case "${sub}" in
      list)    cmd_kapp_list "$@" ;;
      create)  cmd_kapp_create "$@" ;;
      get)     cmd_kapp_get "$@" ;;
      detail)  cmd_kapp_detail "$@" ;;
      delete)  cmd_kapp_delete "$@" ;;
      export)  cmd_kapp_export "$@" ;;
      *)       echo "Usage: kinetic kapp {list|create|get|detail|delete|export}" ;;
    esac
    ;;
  form)
    case "${sub}" in
      list)    cmd_form_list "$@" ;;
      get)     cmd_form_get "$@" ;;
      export)  cmd_form_export "$@" ;;
      delete)  cmd_form_delete "$@" ;;
      *)       echo "Usage: kinetic form {list|get|export|delete}" ;;
    esac
    ;;
  submission)
    case "${sub}" in
      list)    cmd_submission_list "$@" ;;
      get)     cmd_submission_get "$@" ;;
      delete)  cmd_submission_delete "$@" ;;
      *)       echo "Usage: kinetic submission {list|get|delete}" ;;
    esac
    ;;
  bridge)
    case "${sub}" in
      list)  cmd_bridge_list "$@" ;;
      *)     echo "Usage: kinetic bridge {list}" ;;
    esac
    ;;
  webhook)
    case "${sub}" in
      list)  cmd_webhook_list "$@" ;;
      *)     echo "Usage: kinetic webhook {list}" ;;
    esac
    ;;
  version)
    cmd_version "${sub}" "$@" ;;
  help|--help|-h)
    usage ;;
  *)
    echo "Unknown command: ${cmd}"
    usage
    exit 1
    ;;
esac
