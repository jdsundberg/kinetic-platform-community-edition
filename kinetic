cmd_kapp_detail() {
  local space="${1:?Usage: kinetic kapp detail <space_slug> <kapp_slug>}"
  local kapp="${2:?Missing kapp slug}"

  # Kapp info
  echo "=== Kapp: ${kapp} ==="
  _space_api GET "$space" "/kapps/${kapp}?include=details" \
    | python3 -c "
import sys, json
k = json.load(sys.stdin).get('kapp', {})
print(f\"  Name:         {k.get('name','-')}\")
print(f\"  Slug:         {k.get('slug','-')}\")
print(f\"  Display Type: {k.get('displayType','-')}\")
print(f\"  Created:      {k.get('createdAt','-')} by {k.get('createdBy','-')}\")
print(f\"  Updated:      {k.get('updatedAt','-')} by {k.get('updatedBy','-')}\")
" 2>/dev/null

  # Forms
  echo ""
  echo "=== Forms ==="
  _space_api GET "$space" "/kapps/${kapp}/forms?limit=1000&include=details" \
    | python3 -c "
import sys, json
d = json.load(sys.stdin)
forms = d.get('forms', [])
if not forms:
    print('  (none)')
else:
    print(f'  {len(forms)} form(s)')
    print(f'  {\"Name\":<35} {\"Slug\":<25} {\"Status\":<10} Type')
    print(f'  {\"-\"*35} {\"-\"*25} {\"-\"*10} {\"-\"*15}')
    for f in sorted(forms, key=lambda x: x.get('name','')):
        print(f\"  {f.get('name','-'):<35} {f.get('slug','-'):<25} {f.get('status','-'):<10} {f.get('type','-') or '-'}\")
" 2>/dev/null

  # Kapp-level workflows
  echo ""
  echo "=== Kapp Workflows ==="
  _space_api GET "$space" "/kapps/${kapp}/workflows" \
    | python3 -c "
import sys, json
d = json.load(sys.stdin)
wfs = d.get('workflows', [])
if not wfs:
    print('  (none)')
else:
    print(f'  {len(wfs)} workflow(s)')
    for w in wfs:
        print(f\"  {w.get('name','-'):<40} event={w.get('event','-'):<25} status={w.get('status','-')}\")
" 2>/dev/null

  # Per-form workflows
  echo ""
  echo "=== Form Workflows ==="
  _space_api GET "$space" "/kapps/${kapp}/forms?limit=1000" \
    | python3 -c "
import sys, json
forms = json.load(sys.stdin).get('forms', [])
for f in forms:
    print(f'FORM:{f[\"slug\"]}')
" 2>/dev/null | while read -r line; do
    form_slug="${line#FORM:}"
    local wf_json
    wf_json=$(_space_api GET "$space" "/kapps/${kapp}/forms/${form_slug}/workflows")
    echo "$wf_json" | python3 -c "
import sys, json
form_slug = '${form_slug}'
d = json.load(sys.stdin)
wfs = d.get('workflows', [])
if wfs:
    print(f'  [{form_slug}] {len(wfs)} workflow(s)')
    for w in wfs:
        print(f\"    {w.get('name','-'):<38} event={w.get('event','-'):<25} status={w.get('status','-')}\")
" 2>/dev/null
  done

  # Security policies
  echo ""
  echo "=== Security Policies ==="
  _space_api GET "$space" "/kapps/${kapp}/securityPolicyDefinitions" \
    | python3 -c "
import sys, json
pols = json.load(sys.stdin).get('securityPolicyDefinitions', [])
if not pols:
    print('  (none)')
else:
    for p in pols:
        print(f\"  {p.get('name','-'):<30} type={p.get('type','-'):<10} {p.get('message','-')}\")
" 2>/dev/null

  # Webhooks
  echo ""
  echo "=== Webhooks ==="
  _space_api GET "$space" "/kapps/${kapp}/webhooks" \
    | python3 -c "
import sys, json
whs = json.load(sys.stdin).get('webhooks', [])
if not whs:
    print('  (none)')
else:
    for w in whs:
        print(f\"  {w.get('name','-'):<30} event={w.get('event','-'):<20} type={w.get('type','-')}\")
" 2>/dev/null

  # Categories
  echo ""
  echo "=== Categories ==="
  _space_api GET "$space" "/kapps/${kapp}/categories" \
    | python3 -c "
import sys, json
cats = json.load(sys.stdin).get('categories', [])
if not cats:
    print('  (none)')
else:
    for c in cats:
        print(f\"  {c.get('name','-'):<30} slug={c.get('slug','-')}\")
" 2>/dev/null

  # Form types
  echo ""
  echo "=== Form Types ==="
  _space_api GET "$space" "/kapps/${kapp}/formTypes" \
    | python3 -c "
import sys, json
fts = json.load(sys.stdin).get('formTypes', [])
if not fts:
    print('  (none)')
else:
    for ft in fts:
        print(f\"  {ft.get('name','-')}\")
" 2>/dev/null
}

