  local host="${1:?Usage: kinetic system smtp-set <host> <port> <tls> <username> <password> <from_name> <from_address> [validation_email]}"
  local port="${2:?Missing port}"
  local tls="${3:?Missing tls (true/false)}"
  local username="${4:?Missing username}"
  local password="${5:?Missing password}"
  local from_name="${6:?Missing from_name}"
  local from_address="${7:?Missing from_address}"
  local to_address="${8:-}"

  echo "Updating SMTP settings..."
  _api PUT "/app/system-coordinator/api/v1/platform/default-smtp-adapter" \
    -d "$(cat <<EOF
{
  "host": "${host}",
  "port": "${port}",
  "username": "${username}",
  "password": "${password}",
  "tlsEnabled": "${tls}",
  "fromName": "${from_name}",
  "fromAddress": "${from_address}",
  "toAddress": "${to_address}"
}
EOF
)" | _pretty
}

cmd_system_smtp_get() {
  _api GET "/app/system-coordinator/api/v1/platform/default-smtp-adapter" | _pretty
}

cmd_system_list_spaces() {
  _api GET "/app/system-coordinator/api/v1/tenants?limit=100" \
    | python3 -c "import sys,json; [print(t['slug']) for t in json.load(sys.stdin).get('tenants',[])]" 2>/dev/null
}

# List users across all spaces, or a single space when a slug is given.
# Users are read through the system-coordinator core proxy (the same endpoint
# the system console uses), so the system admin token is sufficient — no
# per-space credential is required.
cmd_system_users() {
  local filter="${1:-}"

  # Log in once and reuse the token for every space — re-authenticating per
  # space (the old behavior) is what made the all-spaces listing slow.
  local token base
  token=$(_get_token)
  base="${KINETIC_HOST}/app/system-coordinator/components/core/app/api/v1/spaces"

  local spaces
  if [ -n "$filter" ]; then
    spaces="$filter"
  else
    spaces=$(curl -sk "${KINETIC_HOST}/app/system-coordinator/api/v1/tenants?limit=1000" \
      -H "Authorization: Bearer ${token}" \
      | python3 -c "import sys,json; [print(t['slug']) for t in json.load(sys.stdin).get('tenants',[])]" 2>/dev/null)
  fi

  # When listing ALL spaces, cap each space at 100 users so output stays fast
  # and readable. A single named space shows every user (cap=0 => unlimited).
  local cap=100
  [ -n "$filter" ] && cap=0

  # Stream one block per space as it is fetched, so progress is visible.
  for s in $spaces; do
    echo "=== ${s} ==="
    printf "  %-32s %-8s %-6s %s\n" "USERNAME" "ENABLED" "ADMIN" "EMAIL"

    if [ "$cap" -gt 0 ]; then
      curl -sk "${base}/${s}/users?include=details&limit=${cap}" \
        -H "Authorization: Bearer ${token}" -H 'Accept: application/json' \
        | python3 -c "
import sys, json
cap = ${cap}
s = '${s}'
d = json.load(sys.stdin)
users = sorted(d.get('users', []), key=lambda x: x.get('username', ''))
for u in users:
    enabled = 'yes' if u.get('enabled') else 'NO'
    admin = 'admin' if u.get('spaceAdmin') else ''
    print(f\"  {u.get('username','-'):<32} {enabled:<8} {admin:<6} {u.get('email','') or ''}\")
if d.get('nextPageToken'):
    print(f'  >> {len(users)} shown — MORE THAN {cap} USERS in this space.')
    print(f'  >> run:  kineticCLI system users {s}   to list them all')
else:
    print(f'  {len(users)} user(s)')
" 2>/dev/null || echo "  (unable to read users)"
    else
      local page_token="" resp page_rows count=0
      while :; do
        local q="include=details&limit=1000"
        [ -n "$page_token" ] && q="${q}&pageToken=${page_token}"
        resp=$(curl -sk "${base}/${s}/users?${q}" \
          -H "Authorization: Bearer ${token}" -H 'Accept: application/json')
        page_token=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin).get('nextPageToken') or '')" 2>/dev/null || true)
        page_rows=$(echo "$resp" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for u in sorted(d.get('users', []), key=lambda x: x.get('username', '')):
    enabled = 'yes' if u.get('enabled') else 'NO'
    admin = 'admin' if u.get('spaceAdmin') else ''
    print(f\"  {u.get('username','-'):<32} {enabled:<8} {admin:<6} {u.get('email','') or ''}\")
" 2>/dev/null || true)
        if [ -n "$page_rows" ]; then
          printf '%s\n' "$page_rows"
          count=$((count + $(printf '%s\n' "$page_rows" | grep -c .)))
        fi
        [ -z "$page_token" ] && break
      done
      echo "  ${count} user(s)"
    fi
    echo ""
  done
}


cmd_system_space_create() {
  local space_name="${1:?Usage: kinetic system space-create <name> <admin_user> <email> <display_name> <password>}"
  local username="${2:?Missing admin username}"
  local email="${3:?Missing email}"
  local display_name="${4:?Missing display_name}"
  local password="${5:?Missing password}"
  local slug="${space_name}"

  echo "Creating space '${space_name}'..."
  _api POST "/app/system-coordinator/api/v1/tenants" \
    -d "$(cat <<EOF
{
  "space": {
    "slug": "${slug}",
    "name": "${space_name}"
  },
  "features": {
    "task": "true",
    "integrator": "true"
  },
  "task": {
    "deployment": {
      "image": "",
      "replicas": 1
    },
    "databaseAdapter": {
      "type": "postgres",
      "properties": {
        "host": "postgresql.kinetic.svc.cluster.local",
        "port": "5432",
        "database": "postgres",
        "username": "postgres",
        "sslEnabled": "false",
        "sslmode": "disable"
      }
    },
    "autoCreateDatabase": "true"
  },
  "integrator": {
    "deployment": {
      "image": "",
      "replicas": 1
    },
    "databaseAdapter": {
      "type": "postgres",
      "properties": {
        "host": "postgresql.kinetic.svc.cluster.local",
        "port": "5432",
        "database": "postgres",
        "username": "postgres",
        "sslEnabled": "false",
        "sslmode": "verify-peer"
      }
    },
    "autoCreateDatabase": "true"
  },
  "users": [
    {
      "username": "${username}",
      "password": "${password}",
      "email": "${email}",
      "displayName": "${display_name}"
    }
  ]
}
EOF
)" | _pretty
  echo ""
  echo "Space '${space_name}' created."
}

cmd_system_restart() {
  local component="${1:?Usage: kinetic system restart <component>
Components: agent, core, loghub, indexer, cassandra, elasticsearch, ingress, trusted-certs}"

  case "$component" in
    agent|core|loghub|indexer)
      echo "Restarting ${component}..."
      _api POST "/app/system-coordinator/api/v1/platform/components/${component}/restart" > /dev/null
      echo "  ${component} restart initiated."
      ;;
    cassandra)
      echo "Restarting Cassandra..."
      _api POST "/app/system-coordinator/api/v1/platform/restartResources" \
        -d '{"namespace":"kinetic","label":"platform.kineticdata.com/backend-cassandra"}' > /dev/null
      echo "  Cassandra restart initiated."
      ;;
    elasticsearch)
      echo "Restarting ElasticSearch..."
      _api POST "/app/system-coordinator/api/v1/platform/restartResources" \
        -d '{"namespace":"kinetic","label":"platform.kineticdata.com/backend-elasticsearch"}' > /dev/null
      echo "  ElasticSearch restart initiated."
      ;;
    ingress)
      echo "Restarting Ingress..."
      _api POST "/app/system-coordinator/api/v1/platform/restartResources" \
        -d '{"namespace":"kinetic","label":"platform.kineticdata.com/backend-ingress"}' > /dev/null
      echo "  Ingress restart initiated."
      ;;
    trusted-certs)
      echo "Restarting Trusted Certificates..."
      _api POST "/app/system-coordinator/api/v1/platform/restartResources" \
        -d '{"namespace":"kinetic","label":"platform.kineticdata.com/backend-trusted-certs"}' > /dev/null
      echo "  Trusted Certificates restart initiated."
      ;;
    *)
      echo "Unknown component: ${component}"
      echo "Usage: kinetic system restart <component>"
      echo "Components: agent, core, loghub, indexer, cassandra, elasticsearch, ingress, trusted-certs"
      exit 1
      ;;
  esac
}

