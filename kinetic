#!/bin/bash
#
# kinetic - CLI tool for managing a Kinetic Data Platform instance
#
# Usage: kinetic <command> [subcommand] [args...]
#
# Configuration: Set variables in kinetic.conf (same directory as this script)
# or as environment variables. See kinetic.conf for details.
#
# Changelog:
#   1.4.0  Add 'config create [path]' to write a .config file (mode 600),
#          prompting for each value.
#   1.3.0  'system users' now streams per-space, reuses one login, and caps each
#          space at 100 users in the all-spaces view (flagged when exceeded).
#   1.2.0  Add 'system users [space]' to list users (with enabled status) across
#          all spaces or a single space, via the system-coordinator core proxy.
#   1.1.0  Add 'system info [space]' per-space detail; add --version flag.
#   1.0.0  Initial versioned release.
#

set -euo pipefail

KINETIC_CLI_VERSION="1.4.0"


SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONF="${KINETIC_CONF:-${SCRIPT_DIR}/.config}"

# Configuration precedence: environment variables first, then .config as a
# fallback. Capture any values already set in the environment before sourcing
# the config file, then restore them so they take precedence.
_env_KINETIC_HOST="${KINETIC_HOST:-}"
_env_KINETIC_SYSTEM_USER="${KINETIC_SYSTEM_USER:-}"
_env_KINETIC_SYSTEM_PASS="${KINETIC_SYSTEM_PASS:-}"
_env_KINETIC_SPACE_USER="${KINETIC_SPACE_USER:-}"
_env_KINETIC_SPACE_PASS="${KINETIC_SPACE_PASS:-}"

if [ -f "$CONF" ]; then
  source "$CONF"
fi

# Environment variables win over anything sourced from .config.
KINETIC_HOST="${_env_KINETIC_HOST:-${KINETIC_HOST:-}}"
KINETIC_SYSTEM_USER="${_env_KINETIC_SYSTEM_USER:-${KINETIC_SYSTEM_USER:-}}"
KINETIC_SYSTEM_PASS="${_env_KINETIC_SYSTEM_PASS:-${KINETIC_SYSTEM_PASS:-}}"
KINETIC_SPACE_USER="${_env_KINETIC_SPACE_USER:-${KINETIC_SPACE_USER:-}}"
KINETIC_SPACE_PASS="${_env_KINETIC_SPACE_PASS:-${KINETIC_SPACE_PASS:-}}"

unset _env_KINETIC_HOST _env_KINETIC_SYSTEM_USER _env_KINETIC_SYSTEM_PASS \
  _env_KINETIC_SPACE_USER _env_KINETIC_SPACE_PASS

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

_require_config() {
  if [ -z "$KINETIC_HOST" ]; then
    echo "Error: KINETIC_HOST must be set in ${CONF} or as an environment variable."
    exit 1
  fi
}

_require_system() {
  if [ -z "$KINETIC_SYSTEM_USER" ] || [ -z "$KINETIC_SYSTEM_PASS" ]; then
    echo "Error: KINETIC_SYSTEM_USER and KINETIC_SYSTEM_PASS must be set for system commands."
    exit 1
  fi
}

_require_space() {
  if [ -z "$KINETIC_SPACE_USER" ] || [ -z "$KINETIC_SPACE_PASS" ]; then
    echo "Error: KINETIC_SPACE_USER and KINETIC_SPACE_PASS must be set for space commands."
    exit 1
  fi
}

_get_token() {
  _require_system
  local token
  token=$(curl -sk -X POST "${KINETIC_HOST}/app/system-coordinator/login" \
    -H 'Content-Type: application/json' \
    -d "{\"username\": \"${KINETIC_SYSTEM_USER}\", \"password\": \"${KINETIC_SYSTEM_PASS}\"}" \
    | python3 -c "import sys,json; print(json.load(sys.stdin)['token'])" 2>/dev/null)

  if [ -z "$token" ]; then
    echo "Error: System admin login failed" >&2
    exit 1
  fi
  echo "$token"
}

# System-level API call (requires system admin JWT)
_api() {
  local method="$1" path="$2"
  shift 2
  local token
  token=$(_get_token)
  curl -sk -X "$method" "${KINETIC_HOST}${path}" \
    -H "Authorization: Bearer ${token}" \
    -H 'Content-Type: application/json' \
    -H 'Accept: application/json' \
    "$@"
}

# Space-scoped API call (uses basic auth with space user)
_space_api() {
  _require_space
  local method="$1" space="$2" path="$3"
  shift 3
  curl -sk -X "$method" "${KINETIC_HOST}/${space}/app/api/v1${path}" \
    -u "${KINETIC_SPACE_USER}:${KINETIC_SPACE_PASS}" \
    -H 'Content-Type: application/json' \
    -H 'Accept: application/json' \
    "$@"
}

_pretty() {
  python3 -m json.tool 2>/dev/null || cat
}

# ---------------------------------------------------------------------------
# config - Write the .config file
# ---------------------------------------------------------------------------

# Prompt for a value, falling back to a default when the answer is empty or
# stdin is not a terminal. Pass "secret" as $3 to hide typing.
_config_ask() {
  local prompt="$1" default="$2" secret="${3:-}" answer=""

  if [ ! -t 0 ]; then
    printf '%s\n' "$default"
    return
  fi

  if [ "$secret" = "secret" ]; then
    read -r -s -p "${prompt} [${default}]: " answer </dev/tty || true
    echo >&2
  else
    read -r -p "${prompt} [${default}]: " answer </dev/tty || true
  fi
  printf '%s\n' "${answer:-$default}"
}

cmd_config_create() {
  local target="${1:-$CONF}"

  if [ -e "$target" ]; then
    echo "Error: ${target} already exists. Remove it first or pass a different path." >&2
    exit 1
  fi

  echo "Creating config at ${target} — press Enter to accept the default." >&2
  echo >&2

  local host system_user system_pass space_user space_pass
  host=$(_config_ask "Platform URL      (KINETIC_HOST)" "https://domain.com")
  system_user=$(_config_ask "System admin user (KINETIC_SYSTEM_USER)" "admin")
  system_pass=$(_config_ask "System admin pass (KINETIC_SYSTEM_PASS)" "adminpassword" secret)
  space_user=$(_config_ask "Space user        (KINETIC_SPACE_USER)" "user")
  space_pass=$(_config_ask "Space user pass   (KINETIC_SPACE_PASS)" "userpassword" secret)

  # Create the file with 600 from the start so the credentials are never
  # briefly readable by anyone else.
  (
    umask 077
    cat > "$target" <<EOF
KINETIC_HOST=${host}
# System admin (for 'kinetic system' commands)
KINETIC_SYSTEM_USER=${system_user}
KINETIC_SYSTEM_PASS=${system_pass}

# Space user (for space-scoped commands: user, team, kapp, form, etc.)
KINETIC_SPACE_USER=${space_user}
KINETIC_SPACE_PASS=${space_pass}
EOF
  )
  chmod 600 "$target"

  echo >&2
  echo "Wrote ${target} (mode 600)." >&2
}

# ---------------------------------------------------------------------------
# system - System admin operations
# ---------------------------------------------------------------------------

cmd_system_change_password() {
  local new_password="${1:?Usage: kinetic system change-password <new_password>}"

  echo "Changing system admin password..."
  _api PUT "/app/system-coordinator/api/v1/platform/system-user" \
    -d "$(cat <<EOF
{
  "username": "${KINETIC_SYSTEM_USER}",
  "password": "${new_password}",
  "passwordConfirmation": "${new_password}"
}
EOF
)" | _pretty
  echo ""
  echo "Done. Remember to update kinetic.conf with the new password."
}

# Pretty-print per-space detail (everything except users) from tenant JSON on
# stdin. Accepts either a single-tenant payload ({"tenant":{...}}) or a
# multi-tenant payload ({"tenants":[...]}).
_fmt_spaces() {
  python3 -c "
import sys, json

d = json.load(sys.stdin)
if 'tenants' in d:
    tenants = d['tenants']
elif 'tenant' in d:
    tenants = [d['tenant']]
elif 'slug' in d:
    tenants = [d]
else:
    tenants = []

if not tenants:
    print('  (no spaces)')
    sys.exit(0)

def deployment(comp, label):
    dep = comp.get('deployment') or {}
    if not dep:
        print(f'  -- {label} --')
        print('    (no deployment)')
        return
    status = dep.get('status', '-')
    ready = dep.get('readyReplicas', 0) or 0
    desired = dep.get('specReplicas', 0) or 0
    print(f'  -- {label} --')
    print(f'    Image:       {dep.get(\"image\",\"-\") or \"-\"}')
    print(f'    Status:      {status} ({ready}/{desired} ready)')
    print(f'    Namespace:   {dep.get(\"namespace\",\"-\")}')
    adapter = comp.get('databaseAdapter') or {}
    props = {p.get('name'): p for p in adapter.get('properties', [])}
    def pv(name):
        p = props.get(name, {})
        if p.get('sensitive'):
            return '********' if p.get('value') else '(not set)'
        return p.get('value', '-')
    if props:
        print(f'    Database:    {pv(\"database\")} @ {pv(\"host\")}:{pv(\"port\")} '
              f'(user {pv(\"username\")}, ssl={pv(\"sslEnabled\")})')

for t in sorted(tenants, key=lambda x: x.get('slug', '')):
    s = t.get('space', {})
    feats = t.get('features', {})
    print(f'=== Space: {t.get(\"slug\",\"-\")} ({s.get(\"name\",\"-\")}) ===')
    print(f'  Status:        {s.get(\"status\",\"-\")} — {s.get(\"statusMessage\",\"\") or \"\"}')
    print(f'  Display Type:  {s.get(\"displayType\",\"-\")}')
    print(f'  Display Value: {s.get(\"displayValue\",\"-\") or \"-\"}')
    print(f'  Bundle Base:   {s.get(\"sharedBundleBase\",\"-\") or \"-\"}')
    print(f'  Bundle Path:   {s.get(\"bundlePath\",\"-\") or \"(default)\"}')
    print(f'  Locale:        {s.get(\"defaultLocale\") or \"-\"} (enabled: {\", \".join(s.get(\"enabledLocales\") or []) or \"-\"})')
    print(f'  Timezone:      {s.get(\"defaultTimezone\") or \"-\"}')
    sess = s.get('sessionInactiveLimitInSeconds')
    print(f'  Session Limit: {str(sess)+\"s\" if sess else \"-\"}')
    print(f'  IP Allowlist:  {\"enabled\" if s.get(\"allowedIpsEnabled\") else \"disabled\"}')
    print(f'  Created:       {s.get(\"createdAt\",\"-\")} by {s.get(\"createdBy\",\"-\")}')
    print(f'  Updated:       {s.get(\"updatedAt\",\"-\")} by {s.get(\"updatedBy\",\"-\")}')
    print(f'  Features:      task={feats.get(\"task\",\"-\")} integrator={feats.get(\"integrator\",\"-\")}')
    deployment(t.get('task', {}), 'Task')
    deployment(t.get('integrator', {}), 'Integrator')
    print()
" 2>/dev/null
}

# Print detail for a single space, or all spaces when no slug is given.
cmd_system_space_detail() {
  local space="${1:-}"
  if [ -n "$space" ]; then
    _api GET "/app/system-coordinator/api/v1/tenants/${space}" | _fmt_spaces
  else
    _api GET "/app/system-coordinator/api/v1/tenants?limit=100" | _fmt_spaces
  fi
}

cmd_system_info() {
  # When a space slug is supplied, show only that space's detail.
  local space="${1:-}"
  if [ -n "$space" ]; then
    cmd_system_space_detail "$space"
    return
  fi

  echo "=== Platform Version ==="
  _api GET "/app/system-coordinator/api/v1/version" \
    | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"  Version:      {d.get('version','-')}\")
print(f\"  Build:        {d.get('buildNumber','-')}\")
print(f\"  Build Date:   {d.get('buildDate','-')}\")
" 2>/dev/null

  echo ""
  echo "=== Core Version ==="
  _api GET "/app/system-coordinator/components/core/app/api/v1/version" \
    | python3 -c "
import sys, json
r = json.load(sys.stdin)
d = r.get('version', r)
print(f\"  Version:      {d.get('version','-')}\")
print(f\"  Build:        {d.get('buildNumber','-')}\")
print(f\"  Build Date:   {d.get('buildDate','-')}\")
" 2>/dev/null

  echo ""
  echo "=== License ==="
  _api GET "/app/system-coordinator/components/core/app/api/v1/license/check" \
    | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"  Application:  {d.get('application','-')}\")
print(f\"  License:      {d.get('license','-')}\")
" 2>/dev/null

  echo ""
  echo "=== Admin User ==="
  _api GET "/app/system-coordinator/api/v1/platform/system-user" \
    | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"  Username:     {d.get('username','-')}\")
" 2>/dev/null

  echo ""
  echo "=== SMTP ==="
  _api GET "/app/system-coordinator/api/v1/platform/default-smtp-adapter" \
    | python3 -c "
import sys, json
adapters = json.load(sys.stdin).get('adapter', [])
for a in adapters:
    v = a.get('value', '(not set)')
    if a.get('sensitive'):
        v = '********' if v else '(not set)'
    print(f\"  {a['label']+':':<16}{v}\")
" 2>/dev/null

  echo ""
  echo "=== Database (Task Default) ==="
  _api GET "/app/system-coordinator/api/v1/platform/default-task-db-adapter" \
    | python3 -c "
import sys, json
d = json.load(sys.stdin).get('adapter', {})
print(f\"  Type:         {d.get('type','-')}\")
print(f\"  Name:         {d.get('name','-')}\")
for p in d.get('properties', []):
    v = p.get('value', '(not set)')
    if p.get('sensitive'):
        v = '********' if v else '(not set)'
    print(f\"  {p['label']+':':<16}{v}\")
" 2>/dev/null

  echo ""
  echo "=== Components ==="
  _api GET "/app/system-coordinator/api/v1/platform/components" \
    | python3 -c "
import sys, json
comps = json.load(sys.stdin).get('components', [])
for c in comps:
    print(f\"  {c['name']:<40} {c['status']}\")
" 2>/dev/null

  echo ""
  echo "=== Spaces ==="
  _api GET "/app/system-coordinator/api/v1/tenants?limit=100" \
    | python3 -c "
import sys, json
tenants = json.load(sys.stdin).get('tenants', [])
for t in tenants:
    slug = t.get('slug','-')
    space = t.get('space', {})
    status = space.get('status', '-')
    msg = space.get('statusMessage', '') or ''
    print(f\"  {slug:<30} {status:<12} {msg}\")
" 2>/dev/null

  echo ""
  echo "=== Connection ==="
  echo "  Host:         ${KINETIC_HOST}"
  echo "  Admin User:   ${KINETIC_SYSTEM_USER}"

  echo ""
  echo "=== Space Details ==="
  echo ""
  cmd_system_space_detail
}

cmd_system_health() {
  local all_ok=true

  echo "=== Component Health ==="
  _api GET "/app/system-coordinator/api/v1/platform/components" \
    | python3 -c "
import sys, json
comps = json.load(sys.stdin).get('components', [])
bad = 0
for c in comps:
    status = c['status']
    icon = 'OK' if status == 'Running' else 'WARN'
    if status != 'Running':
        bad += 1
    print(f'  [{icon}] {c[\"name\"]:<40} {status}')
print()
if bad > 0:
    print(f'  {bad} component(s) not running')
    sys.exit(1)
else:
    print(f'  All {len(comps)} components running')
" 2>/dev/null || all_ok=false

  echo ""
  echo "=== License Health ==="
  _api GET "/app/system-coordinator/components/core/app/api/v1/license/check" \
    | python3 -c "
import sys, json
d = json.load(sys.stdin)
app = d.get('application', '-')
lic = d.get('license', '-')
icon = 'OK' if app == 'Running' else 'WARN'
print(f'  [{icon}] Application: {app}')
print(f'  License: {lic}')
" 2>/dev/null

  echo ""
  echo "=== Space Health ==="
  _api GET "/app/system-coordinator/api/v1/tenants?limit=100" \
    | python3 -c "
import sys, json
tenants = json.load(sys.stdin).get('tenants', [])
bad = 0
for t in tenants:
    slug = t.get('slug','-')
    space = t.get('space', {})
    status = space.get('status', '-')
    msg = space.get('statusMessage', '') or ''
    icon = 'OK' if status == 'Active' else 'WARN'
    if status != 'Active':
        bad += 1
    print(f'  [{icon}] {slug:<30} {status:<12} {msg}')

    # Check integrator/task deployments
    for comp in ('integrator', 'task'):
        dep = t.get(comp, {}).get('deployment', {})
        if dep:
            dep_status = dep.get('status', '-')
            ready = dep.get('readyReplicas', 0) or 0
            desired = dep.get('specReplicas', 0) or 0
            dep_icon = 'OK' if dep_status == 'Running' and ready >= desired else 'WARN'
            print(f'        [{dep_icon}] {comp:<20} {dep_status} ({ready}/{desired} replicas)')
print()
if bad > 0:
    print(f'  {bad} space(s) not active')
else:
    print(f'  All {len(tenants)} space(s) active')
" 2>/dev/null

  echo ""
  echo "=== Notifications ==="
  _api GET "/app/system-coordinator/api/v1/platform/notifications" \
    | python3 -c "
import sys, json
notes = json.load(sys.stdin)
if not notes:
    print('  No notifications')
else:
    for n in notes:
        print(f'  - {n}')
" 2>/dev/null
}

